# === Required ===
# Firecrawl API key — get from https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-YOUR_KEY_HERE

# Anthropic API key — get from https://console.anthropic.com/settings/keys
# Required for Tier 3 vision fallback (used when Firecrawl can't render
# JS-heavy pages like Albatros and Stjernegaard's priser-og-datoer).
# Cost: ~$0.02 per fallback call, only invoked when Tier 1 fails.
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# === Optional ===
# Override default DB paths
# TOPAS_DB_PATH=data/snapshots.db
# TOPAS_CATALOG_DB_PATH=data/catalog.db
